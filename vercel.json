{
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/en",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/vi.html",
      "destination": "/vi/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/richlane-residence/:path*",
      "destination": "https://richlane-web.pages.dev/:path*"
    }
  ]
}